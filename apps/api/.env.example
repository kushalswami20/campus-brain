NODE_ENV=development

# ── Where this API listens ──────────────────────────────────────────────
# PORT: the API's own port. API_PREFIX: routes are served under /<prefix>/*
# (e.g. /api/auth/login). Keep API_PREFIX identical to the web app's
# NEXT_PUBLIC_API_PREFIX, or the frontend will 404.
PORT=3001
API_PREFIX=api

# Point at the Compose Postgres from the repo root (infra/docker/docker-compose.yml).
DATABASE_URL=postgresql://campusbrain:campusbrain@localhost:5432/campusbrain?schema=public

# Auth (Milestone 2) — REQUIRED. Use long random strings in production.
JWT_ACCESS_SECRET=dev-access-secret-change-me-please
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-please
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
BCRYPT_ROUNDS=12

# Queue/cache (Milestone 4b) — BullMQ ingestion jobs.
REDIS_URL=redis://localhost:6379

# Storage (Milestone 4b). 'local' writes under UPLOAD_DIR; 'cloudinary' needs URL.
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=25
# CLOUDINARY_URL=cloudinary://key:secret@cloud

# ── Where the AI microservice lives (this API calls it) ─────────────────
AI_SERVICE_URL=http://localhost:8000
# AI_SERVICE_KEY=

LOG_LEVEL=info
# ── Which web origin may call this API (the browser's URL) ───────────────
CORS_ORIGINS=http://localhost:3000
