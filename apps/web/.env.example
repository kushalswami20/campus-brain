# ── Where the web app finds the API ─────────────────────────────────────
# NEXT_PUBLIC_API_URL: the NestJS API's base URL (host + port, NO trailing slash).
# NEXT_PUBLIC_API_PREFIX: the API's route prefix; MUST match apps/api/.env API_PREFIX.
# Requests go to  <NEXT_PUBLIC_API_URL>/<NEXT_PUBLIC_API_PREFIX>/...
# e.g. http://localhost:3001/api/auth/login
#
# NOTE: NEXT_PUBLIC_* values are inlined at BUILD time — restart/redeploy after changing.
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_API_PREFIX=api
