APP_ENV=development
PORT=8000
LOG_LEVEL=INFO

# Shared secret for NestJS -> AI calls. Leave empty for local dev (auth becomes
# a no-op); set the same value here and as AI_SERVICE_KEY in the API for prod.
SERVICE_API_KEY=

# AI providers — required from Milestone 4/5 onward.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
EMBEDDING_MODEL=text-embedding-3-large

PINECONE_API_KEY=
PINECONE_INDEX=campusbrain

AI_REDIS_URL=redis://localhost:6379/1

DEFAULT_TOP_K=8
REQUEST_TIMEOUT_SECONDS=60
